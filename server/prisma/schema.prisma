// Prisma schema — Système de tickets WCA + IDC (PostgreSQL)
// Convention : champs JS en camelCase, colonnes SQL en snake_case via @map.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  MEMBER      // tout le monde : peut soumettre ET intervenir sur les demandes de son service
  ADMIN       // vue globale + gestion
  SUPER_ADMIN // réservé / inutilisé — le backoffice éditeur a ses propres comptes (table SuperAdmin)
}

enum Urgency {
  NORMAL
  HIGH
  URGENT
}

enum TicketType {
  INTERVENTION // quelque chose ne fonctionne pas, action corrective attendue
  NEED // demande de prestation, ressource ou service à planifier
}

enum Space {
  GLOBAL
  WCA
  IDC
}

enum TicketStatus {
  NEW
  IN_PROGRESS
  ON_HOLD
  RESOLVED
  CLOSED
}

// Disponibilité déclarée par l'utilisateur. « En ligne / Pas en ligne » est dérivé des connexions socket ;
// AVAILABLE laisse donc parler la présence réelle, UNAVAILABLE/ON_LEAVE priment sur l'état en ligne.
enum Presence {
  AVAILABLE   // disponible (l'état affiché suit la connexion : en ligne / pas en ligne)
  UNAVAILABLE // indisponible
  ON_LEAVE    // en congé
}

model Company {
  id    String @id @default(cuid())
  name  String // "WCA" | "IDC"
  slug  String @unique // "wca" | "idc"
  color String // "#185FA5" (WCA) | "#BA7517" (IDC)

  users         User[]
  departments   Department[]
  sourceTickets Ticket[] @relation("TicketSource")

  @@map("companies")
}

model Department {
  id        String  @id @default(cuid())
  name      String
  code      String  @unique
  companyId String? @map("company_id") // null = service commun aux deux entreprises
  company   Company? @relation(fields: [companyId], references: [id])

  // Responsable du service (désigné par l'admin) : peut créer/gérer le salon du service.
  responsibleId String? @map("responsible_id")
  responsible   User?   @relation("DeptResponsible", fields: [responsibleId], references: [id])

  agents   User[]    @relation("DeptMembers")
  tickets  Ticket[]
  chatRoom ChatRoom?

  @@index([companyId])
  @@map("departments")
}

model User {
  id           String      @id @default(cuid())
  name         String
  email        String      @unique
  passwordHash String      @map("password_hash")
  role         Role        @default(MEMBER)

  companyId    String      @map("company_id")
  company      Company     @relation(fields: [companyId], references: [id])

  departmentId String?     @map("department_id")
  department   Department? @relation("DeptMembers", fields: [departmentId], references: [id])

  createdAt    DateTime    @default(now()) @map("created_at")

  // Préférences de notification hors-site
  notifyEmail Boolean @default(true) @map("notify_email")
  notifyPush  Boolean @default(true) @map("notify_push")

  // Disponibilité déclarée (présence en ligne/hors-ligne calculée côté socket)
  presence Presence @default(AVAILABLE)

  submittedTickets  Ticket[]         @relation("TicketSubmitter")
  assignedTickets   Ticket[]         @relation("TicketAssignee")
  suggestedTickets  Ticket[]         @relation("TicketSuggested")
  transferTickets   Ticket[]         @relation("TicketTransfer")
  comments          Comment[]
  uploadedDocuments TicketDocument[]
  notifications     Notification[]
  actedEvents       TicketEvent[]
  pushSubscriptions PushSubscription[]
  managedDepartments Department[]    @relation("DeptResponsible")
  chatMessages       ChatMessage[]
  chatReads          ChatRead[]

  @@index([role])
  @@index([companyId])
  @@index([departmentId])
  @@map("users")
}

model Ticket {
  id          String       @id @default(cuid())
  reference   String       @unique // numéro affiché, ex: TCK-000123
  title       String
  description String
  category    String // libellé choisi dans le formulaire
  type        TicketType   @default(INTERVENTION)
  urgency     Urgency      @default(NORMAL)
  status      TicketStatus @default(NEW)

  // Espace d'origine de la demande (trace : /global, /wca, /idc).
  sourceSpace Space @default(GLOBAL) @map("source_space")

  // Entreprise émettrice (badge WCA bleu / IDC orange).
  sourceCompanyId String  @map("source_company_id")
  sourceCompany   Company @relation("TicketSource", fields: [sourceCompanyId], references: [id])

  // Service destinataire (peut être commun, WCA ou IDC).
  departmentId String     @map("department_id")
  department   Department @relation(fields: [departmentId], references: [id])

  submittedById String @map("submitted_by")
  submitter     User   @relation("TicketSubmitter", fields: [submittedById], references: [id])

  assignedToId String? @map("assigned_to")
  assignee     User?   @relation("TicketAssignee", fields: [assignedToId], references: [id])

  // Membre suggéré par le demandeur (indication douce, n'assigne pas).
  suggestedToId String? @map("suggested_to")
  suggestedTo   User?   @relation("TicketSuggested", fields: [suggestedToId], references: [id])

  // Transfert en attente d'acceptation (proposé par l'assigné à un collègue du service).
  transferToId String? @map("transfer_to")
  transferTo   User?   @relation("TicketTransfer", fields: [transferToId], references: [id])

  attachmentUrl String?   @map("attachment_url")

  // Lien de dépendance : ce ticket-besoin a été créé pour débloquer un ticket en attente (parent).
  parentId String?  @map("parent_id")
  parent   Ticket?  @relation("TicketLink", fields: [parentId], references: [id], onDelete: SetNull)
  children Ticket[] @relation("TicketLink")

  // Demande de congé (renseigné quand la demande est un congé adressé aux RH).
  leaveStart DateTime? @map("leave_start")
  leaveEnd   DateTime? @map("leave_end")
  leaveKind  String?   @map("leave_kind") // "paye" | "maladie" | "sans-solde" | "autre"

  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @updatedAt @map("updated_at")
  resolvedAt    DateTime? @map("resolved_at")

  comments      Comment[]
  feedback      Feedback?
  documents     TicketDocument[]
  attachments   TicketAttachment[]
  notifications Notification[]
  events        TicketEvent[]

  @@index([departmentId, status])
  @@index([submittedById])
  @@index([assignedToId])
  @@index([sourceCompanyId])
  @@index([sourceSpace])
  @@index([type])
  @@map("tickets")
}

model Comment {
  id         String   @id @default(cuid())
  ticketId   String   @map("ticket_id")
  ticket     Ticket   @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  authorId   String   @map("author_id")
  author     User     @relation(fields: [authorId], references: [id])
  content    String
  isInternal Boolean  @default(false) @map("is_internal")
  createdAt  DateTime @default(now()) @map("created_at")
  editedAt   DateTime? @map("edited_at")

  @@index([ticketId])
  @@map("comments")
}

model TicketDocument {
  id           String   @id @default(cuid())
  ticketId     String   @map("ticket_id")
  ticket       Ticket   @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  url          String
  name         String
  uploadedById String   @map("uploaded_by")
  uploadedBy   User     @relation(fields: [uploadedById], references: [id])
  createdAt    DateTime @default(now()) @map("created_at")

  @@index([ticketId])
  @@map("ticket_documents")
}

// Pièces jointes fournies par le demandeur à la création (plusieurs fichiers possibles).
model TicketAttachment {
  id        String   @id @default(cuid())
  ticketId  String   @map("ticket_id")
  ticket    Ticket   @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  url       String
  name      String
  createdAt DateTime @default(now()) @map("created_at")

  @@index([ticketId])
  @@map("ticket_attachments")
}

model TicketEvent {
  id        String   @id @default(cuid())
  ticketId  String   @map("ticket_id")
  ticket    Ticket   @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  actorId   String?  @map("actor_id")
  actor     User?    @relation(fields: [actorId], references: [id])
  action    String // created | status | assigned | unassigned | reassigned | transfer_proposed | transfer_accepted | transfer_refused | transfer_cancelled | comment | document | feedback
  detail    String? // JSON sérialisé (ex. {from,to})
  createdAt DateTime @default(now()) @map("created_at")

  @@index([ticketId])
  @@index([createdAt])
  @@map("ticket_events")
}

enum ChatScope {
  GLOBAL
  DEPARTMENT
}

model ChatRoom {
  id           String      @id @default(cuid())
  name         String
  scope        ChatScope
  departmentId String?     @unique @map("department_id") // null = salon global
  department   Department? @relation(fields: [departmentId], references: [id], onDelete: Cascade)
  archived     Boolean     @default(false)
  createdAt    DateTime    @default(now()) @map("created_at")

  messages      ChatMessage[]
  notifications Notification[]
  reads         ChatRead[]

  @@map("chat_rooms")
}

model ChatMessage {
  id        String   @id @default(cuid())
  roomId    String   @map("room_id")
  room      ChatRoom @relation(fields: [roomId], references: [id], onDelete: Cascade)
  authorId  String   @map("author_id")
  author    User     @relation(fields: [authorId], references: [id])
  content   String
  attachmentUrl  String? @map("attachment_url")
  attachmentName String? @map("attachment_name")
  createdAt DateTime @default(now()) @map("created_at")

  @@index([roomId])
  @@map("chat_messages")
}

// Marqueur de dernière lecture d'un salon par un utilisateur → compteur de messages non lus.
model ChatRead {
  id         String   @id @default(cuid())
  userId     String   @map("user_id")
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  roomId     String   @map("room_id")
  room       ChatRoom @relation(fields: [roomId], references: [id], onDelete: Cascade)
  lastReadAt DateTime @default(now()) @map("last_read_at")

  @@unique([userId, roomId])
  @@map("chat_reads")
}

model PushSubscription {
  id        String   @id @default(cuid())
  userId    String   @map("user_id")
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  endpoint  String   @unique
  p256dh    String
  auth      String
  createdAt DateTime @default(now()) @map("created_at")

  @@index([userId])
  @@map("push_subscriptions")
}

model Setting {
  key   String @id
  value String

  @@map("settings")
}

model Notification {
  id        String   @id @default(cuid())
  userId    String   @map("user_id")
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  type      String // new_ticket | suggested | assigned | status | comment | transfer_* | chat
  text      String
  ticketId  String?  @map("ticket_id")
  ticket    Ticket?  @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  roomId    String?  @map("room_id")
  room      ChatRoom? @relation(fields: [roomId], references: [id], onDelete: Cascade)
  read      Boolean  @default(false)
  createdAt DateTime @default(now()) @map("created_at")

  @@index([userId, read])
  @@map("notifications")
}

model Feedback {
  id        String   @id @default(cuid())
  ticketId  String   @unique @map("ticket_id")
  ticket    Ticket   @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  rating    Int // 1 à 5
  comment   String?
  createdAt DateTime @default(now()) @map("created_at")

  @@map("feedback")
}

// ============================================================
// Backoffice SaaS (éditeur Quitus) — clients, abonnements, facturation, revenus.
// Entièrement autonome : aucun lien avec les modèles du frontoffice (Company, User…).
// Connexion et comptes SÉPARÉS du frontoffice (table SuperAdmin dédiée).
// ============================================================

// Compte du personnel de l'éditeur Quitus (PAS un utilisateur client).
// Login distinct (/api/superadmin/auth/login) → aucun lien avec User/Company.
model SuperAdmin {
  id           String   @id @default(cuid())
  name         String
  email        String   @unique
  passwordHash String   @map("password_hash")
  createdAt    DateTime @default(now()) @map("created_at")

  @@map("super_admins")
}

model Tenant {
  id            String       @id @default(cuid())
  name          String
  plan          Plan         @default(STARTER)
  status        TenantStatus @default(TRIAL)
  trial_ends_at DateTime?
  billing_cycle BillingCycle @default(MONTHLY)
  next_renewal  DateTime?
  contact_email String
  contact_phone String?
  churned_at    DateTime? // date de résiliation (statut → CHURNED) pour le calcul du churn
  created_at    DateTime     @default(now())

  // Signaux de santé (le tenant n'est pas relié au frontoffice : ces signaux sont
  // alimentés par seed/intégration externe ; la facturation, elle, est dérivée des factures).
  last_activity_at    DateTime?
  tickets_30d         Int       @default(0)
  tickets_90d_avg     Int       @default(0)
  open_escalations    Int       @default(0)
  escalations_over_24h Int      @default(0)

  // Connexion-en-tant-que : utilisateur frontoffice « consulté en tant que » (optionnel).
  frontoffice_user_id String?

  invoices        Invoice[]
  payments        Payment[]
  healthSnapshots HealthSnapshot[]

  @@map("tenants")
}

// Historisation du score de santé client (le dernier snapshot fait foi à l'affichage).
model HealthSnapshot {
  id         String       @id @default(cuid())
  tenant_id  String
  tenant     Tenant       @relation(fields: [tenant_id], references: [id], onDelete: Cascade)
  score      Int          // 0–100
  bucket     HealthBucket
  usage      Int
  engagement Int
  support    Int
  billing    Int
  computed_at DateTime    @default(now())

  @@index([tenant_id, computed_at])
  @@map("health_snapshots")
}

enum HealthBucket {
  SAIN
  A_SURVEILLER
  A_RISQUE
}

// Catalogue tarifaire des plans (prix mensuel en FCFA) — base du calcul MRR/ARR.
model PlanPrice {
  id          String   @id @default(cuid())
  plan        Plan     @unique
  monthly_fcfa Int
  updated_at  DateTime @updatedAt

  @@map("plan_prices")
}

// Journal d'audit des actions du backoffice (append-only).
model SuperAdminAudit {
  id         String   @id @default(cuid())
  admin_id   String
  admin_email String
  action     String // tenant.create|update | invoice.create|pay|cancel | IMPERSONATION_START|END
  detail     String? // résumé lisible
  tenant_id      String? // cible (compte client) le cas échéant
  target_user_id String? // utilisateur frontoffice consulté (impersonation)
  ip             String?
  created_at DateTime @default(now())

  @@index([created_at])
  @@map("super_admin_audits")
}

model Invoice {
  id          String        @id @default(cuid())
  tenant_id   String
  tenant      Tenant        @relation(fields: [tenant_id], references: [id], onDelete: Cascade)
  amount_fcfa Int
  status      InvoiceStatus @default(PENDING)
  due_date    DateTime
  paid_at     DateTime?
  notes       String?
  created_at  DateTime      @default(now())

  @@index([tenant_id])
  @@map("invoices")
}

model Payment {
  id              String        @id @default(cuid())
  tenant_id       String
  tenant          Tenant        @relation(fields: [tenant_id], references: [id], onDelete: Cascade)
  amount_fcfa     Int
  method          PaymentMethod
  transaction_ref String?
  paid_at         DateTime      @default(now())

  @@index([tenant_id])
  @@map("payments")
}

enum Plan {
  STARTER
  ESSENTIEL
  PME
  ENTERPRISE
}

enum TenantStatus {
  TRIAL
  ACTIVE
  SUSPENDED
  CHURNED
}

enum BillingCycle {
  MONTHLY
  QUARTERLY
  ANNUAL
}

enum InvoiceStatus {
  PENDING
  PAID
  OVERDUE
  CANCELLED
}

enum PaymentMethod {
  WAVE
  ORANGE_MONEY
  MTN_MOMO
  BANK_TRANSFER
}
