# --- Base de données PostgreSQL ---
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/ticketdb?schema=public"

# --- Serveur ---
PORT=4000
# Origine(s) autorisée(s) pour le CORS (REST + WebSocket).
# Dev : URL du frontend Vite. Prod : URL du front Vercel.
# Plusieurs origines possibles, séparées par des virgules.
CLIENT_URL="http://localhost:5173"

# --- Auth ---
JWT_SECRET="change-me-en-une-chaine-longue-et-aleatoire"
JWT_EXPIRES_IN="7d"

# --- Email (Resend) ---
# Laisser RESEND_API_KEY vide en dev : les emails sont alors loggés en console.
RESEND_API_KEY=""
EMAIL_FROM="Support <support@demo.local>"

# --- Web Push (notifications navigateur) ---
# Générer une paire avec : npx web-push generate-vapid-keys
VAPID_PUBLIC_KEY=""
VAPID_PRIVATE_KEY=""
VAPID_SUBJECT="mailto:support@demo.local"

# --- Uploads ---
# Dossier de stockage des pièces jointes. Relatif (→ server/uploads) ou ABSOLU
# (prod : ex. /data/uploads sur un disque persistant Render).
UPLOAD_DIR="uploads"
